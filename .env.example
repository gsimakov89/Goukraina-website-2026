# Copy to .env and fill values (never commit .env, .env.local, or any file with real keys).
# Production Supabase URL fallback is set in pipeline/config.py and api/* defaults; override with SUPABASE_URL if needed.

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_ANON_KEY=          # Dashboard → Settings → API (publishable; also exposed to admin via /api/supabase-public-config)
# SUPABASE_SERVICE_ROLE_KEY=  # Secret — server only (Vercel env, never in client or Git)
# SUPABASE_JWT_SECRET=        # Secret — Supabase → Settings → API → JWT signing secret (for /api admin routes)

# After DB migrate: run supabase/seed_admin_user.sql once (or set user App metadata admin: true).
#
# Vercel: copy into Project → Environment Variables — see VERCEL.md.

# Admin SPA (optional): point at Supabase Edge Function site-api instead of same-origin /api.
# VITE_SUPABASE_FUNCTIONS_URL=https://YOUR_PROJECT_REF.supabase.co/functions/v1/site-api
