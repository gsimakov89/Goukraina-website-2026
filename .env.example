# Copy to .env and fill secrets (never commit .env).
# Project URL defaults in pipeline/config.py; set SUPABASE_URL only to override.

SUPABASE_URL=https://lrbrvkhddhuebmyazgcf.supabase.co
# SUPABASE_ANON_KEY=          # public key — admin SPA + /api/supabase-public-config
# SUPABASE_SERVICE_ROLE_KEY=  # secret — Vercel APIs, local FastAPI, python build_site.py (blog from DB)
# SUPABASE_JWT_SECRET=        # Required for /admin API — copy from Supabase → Settings → API → JWT Secret (same project as anon key)

# After DB migrate: run supabase/seed_admin_user.sql once (or set user App metadata admin: true).
#
# Vercel: copy these into Project → Environment Variables — see VERCEL.md.

# Admin SPA (Vite): when set, the admin UI calls Supabase Edge Function `site-api` instead of same-origin /api (Vercel serverless).
# Deploy: supabase functions deploy site-api — then set in Vercel (or admin/.env for local Edge testing):
# VITE_SUPABASE_FUNCTIONS_URL=https://lrbrvkhddhuebmyazgcf.supabase.co/functions/v1/site-api
